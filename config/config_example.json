      "RemoteRepo": "ssh://user@host:port/path/to/repo1",
      "ArchiveName": "{now:$Timestamp}",
      "EncryptionPwd": "supersecurePassword1337",
      "Repo_Initialized": false,
      "dry_run": false,
      "active": true,
      "Cleanup": {
        "daily": "14",
        "monthly": "6",
        "yearly": "1"
      }
    },
    {
      "Name": "Software 2",
      "SourcePath": ["/mnt/tools/backupdir2"],
