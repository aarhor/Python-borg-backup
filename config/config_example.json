{
  "General": {
    "Timestamp": "%Y-%m-%d",
    "Logging": {
      "Logfolder": "/var/lib/log/pythonBorgBackup/",
      "LogLevel_Mail": "INFO",
      "LogLevel_File": "DEBUG"
    },
    "Allow Relocated Repos": "no",
    "LogRotation": 21
  },
  "backup": [
    {
      "Name": "Software 1",
      "SourcePath": ["/mnt/tools/backupdir1", "/mnt/tools/backupdir1337"],
